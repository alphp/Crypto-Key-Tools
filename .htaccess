<IfModule rewrite_module>
	RewriteEngine On

	RewriteCond %{REQUEST_URI} .editorconfig [OR]
	RewriteCond %{REQUEST_URI} .git [OR]
	RewriteCond %{REQUEST_URI} vendor [OR]
	RewriteCond %{REQUEST_URI} composer [OR]
	RewriteCond %{REQUEST_URI} README.md
  RewriteRule .* - [R=404,L]

  RewriteCond %{REQUEST_URI} (generate|convert)$
  RewriteRule . https://%{HTTP_HOST}%{REQUEST_URI}/ [L,R=302]

  RewriteCond %{REQUEST_METHOD} ^GET$
  RewriteCond %{REQUEST_URI} generate/$
  RewriteRule . index.html [L]

  RewriteCond %{REQUEST_METHOD} ^POST$
  RewriteCond %{REQUEST_URI} generate/$
  RewriteRule . generate.php [L]

  RewriteCond %{REQUEST_METHOD} ^GET$
  RewriteCond %{REQUEST_URI} convert/$
  RewriteRule . convert.html [L]

  RewriteCond %{REQUEST_METHOD} ^POST$
  RewriteCond %{REQUEST_URI} convert/$
  RewriteRule . convert.php [L]
</IfModule>
