<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <!-- 1. Detener el proceso si se solicita index.php directamente -->
                <rule name="Detener index.php" stopProcessing="true">
                    <match url="^index\.php$" />
                    <action type="None" />
                </rule>

                <!-- 2. Enrutador Frontal Dinámico (Equivalente a tus condiciones !-f y !-d) -->
                <rule name="Enrutador Frontal" stopProcessing="true">
                    <match url="." />
                    <conditions logicalGrouping="MatchAll">
                        <!-- Condición: Si NO es un archivo físico existente -->
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                        <!-- Condición: Si NO es una carpeta física existente -->
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                    </conditions>
                    <!-- Redirige dinámicamente a index.php en la carpeta actual -->
                    <action type="Rewrite" url="index.php" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
